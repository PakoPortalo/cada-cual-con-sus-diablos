# Copia a .env. Valores del proyecto Supabase (Project Settings → API).

# Base de la API. Usa "/api" tanto en LOCAL (Vite lo proxea a localhost:3001)
# como en PRODUCCIÓN (Caddy lo reenvía al backend). Mismo origen => sin CORS.
VITE_API_URL=/api

# Supabase — solo para el LOGIN del modo Dev (Auth). La ANON key es publica.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
