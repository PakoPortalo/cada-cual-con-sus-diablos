# Copia este archivo a .env y rellena con los valores de tu proyecto Supabase
# (Project Settings → API). NO commitear .env.

# URL del proyecto, p.ej. https://xxxxxxxx.supabase.co
SUPABASE_URL=

# Service role key (secreta, solo backend — salta RLS). NUNCA en el frontend.
SUPABASE_SERVICE_KEY=

# Nombre del bucket de Storage (publico) donde se guardan SVG/JPEG.
SUPABASE_BUCKET=diablos

# Puerto del servidor Express.
PORT=3001

# Origen permitido para CORS (la URL del frontend en dev).
CORS_ORIGIN=http://localhost:5173
